<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Urwah" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/urwah_primary</item>
        <item name="android:windowBackground">@color/urwah_background</item>
        <item name="android:statusBarColor">@color/urwah_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:fontFamily">@font/noto_naskh_arabic</item>
    </style>

    <style name="UrwahTitleStyle">
        <item name="android:textColor">@color/urwah_thread_dark</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>