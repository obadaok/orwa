<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/urwah_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/urwah_nav_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="رجوع"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/urwah_thread_dark" />

        <ImageButton
            android:id="@+id/btnAutoScroll"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="التمرير التلقائي"
            android:padding="8dp"
            android:src="@drawable/ic_scroll_play"
            android:tint="@color/urwah_thread_dark" />

        <TextView
            android:id="@+id/tvSurahTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/alyamama"
            android:gravity="center"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnViewMode"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="طريقة العرض"
            android:padding="8dp"
            android:src="@drawable/ic_book_black_24dp"
            android:tint="@color/urwah_thread_dark"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btnBookmarks"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="الإشارات المرجعية"
            android:padding="8dp"
            android:src="@drawable/ic_bookmark"
            android:tint="@color/urwah_thread_dark" />

        <ImageButton
            android:id="@+id/btnJumpToAyah"
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="الانتقال إلى آية"
            android:padding="8dp"
            android:src="@drawable/ic_search"
            android:tint="@color/urwah_thread_dark" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/urwah_shadow_faint" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_surah_header_box"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="18dp">

                        <TextView
                            android:id="@+id/tvSurahOrnamentalName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/uthmanic_hafs"
                            android:gravity="center"
                            android:textColor="@color/urwah_thread_dark"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="28dp"
                                android:layout_height="1.5dp"
                                android:background="@color/urwah_thread_light" />

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:layout_marginHorizontal="6dp"
                                android:background="@drawable/bg_ayah_number" />

                            <View
                                android:layout_width="28dp"
                                android:layout_height="1.5dp"
                                android:background="@color/urwah_thread_light" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSurahMeta"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/alyamama"
                            android:textColor="@color/urwah_thread_brown"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="6dp"
                        android:rotation="0"
                        android:src="@drawable/ic_ornament_corner"
                        android:tint="@color/urwah_thread_light"
                        android:contentDescription="@null" />

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="12dp"
                        android:rotation="90"
                        android:src="@drawable/ic_ornament_corner"
                        android:tint="@color/urwah_thread_light"
                        android:contentDescription="@null" />

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp"
                        android:rotation="270"
                        android:src="@drawable/ic_ornament_corner"
                        android:tint="@color/urwah_thread_light"
                        android:contentDescription="@null" />

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="12dp"
                        android:rotation="180"
                        android:src="@drawable/ic_ornament_corner"
                        android:tint="@color/urwah_thread_light"
                        android:contentDescription="@null" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/basmalaContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginHorizontal="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        android:layout_marginBottom="5dp"
                        android:background="@drawable/bg_surah_header_box"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:id="@+id/tvBasmala"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/uthmanic_hafs"
                            android:gravity="center"
                            android:text="بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ"
                            android:textColor="@color/urwah_thread_dark"
                            android:textIsSelectable="false"
                            android:textSize="24sp" />

                    </LinearLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginHorizontal="16dp">

                    <LinearLayout
                        android:id="@+id/containerAyahs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_surah_header_box"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="18dp" />

                </FrameLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/pageViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:layout_marginHorizontal="0dp" />

    </FrameLayout>

</LinearLayout>
