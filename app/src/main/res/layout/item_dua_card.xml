<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dhikr_shadow_rect" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDuaItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="5dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/urwah_thread_dark"
        app:cardBackgroundColor="@color/card_background"
        app:contentPadding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDuaItemTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/alyamama"
                    android:textColor="@color/urwah_thread_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvDuaItemSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/alyamama"
                    android:textColor="@color/urwah_thread_brown"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDuaItemPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/alyamama"
                android:textColor="@color/urwah_thread_dark"
                android:textSize="20sp"
                android:gravity="center"
                android:textDirection="rtl"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
