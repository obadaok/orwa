<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toast_neo_brutal"
        android:gravity="center"
        android:minWidth="220dp"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="@color/urwah_thread_dark">

            <TextView
                android:id="@+id/tvToastIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/uthmanic_hafs"
                android:text="\u00BC"
                android:textColor="@color/urwah_card_bg"
                android:textSize="18sp"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvToastTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_naskh_arabic"
                android:gravity="end"
                android:text="\u0631\u0628\u0639 \u0627\u0644\u062D\u0632\u0628"
                android:textColor="@color/urwah_thread_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvToastLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/noto_naskh_arabic"
                android:gravity="end"
                android:text="\u0627\u0644\u062D\u0632\u0628 \u0627\u0644\u062B\u0627\u0644\u062B"
                android:textColor="@color/urwah_thread_light"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
