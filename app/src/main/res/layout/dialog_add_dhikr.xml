<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surah_header_box"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/alyamama"
        android:text="إضافة ذكر جديد"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_thread_brown" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alyamama"
        android:text="نص الذكر:"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etDhikrText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_surah_header_box"
        android:fontFamily="@font/alyamama"
        android:gravity="center"
        android:minHeight="60dp"
        android:padding="12dp"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_shadow_faint" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alyamama"
        android:text="التكرار:"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <NumberPicker
        android:id="@+id/pickerRepeats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:descendantFocusability="blocksDescendants"
        android:theme="@style/NumberPickerTheme" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="6dp"
        android:background="@color/urwah_shadow_faint" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alyamama"
        android:text="الفضل (اختياري):"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etVirtue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_surah_header_box"
        android:fontFamily="@font/alyamama"
        android:gravity="center"
        android:minHeight="50dp"
        android:padding="10dp"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_shadow_faint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSaveDhikr"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="@font/alyamama"
            android:text="حفظ"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnCancelDhikr"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_secondary_button"
            android:fontFamily="@font/alyamama"
            android:text="إلغاء"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
