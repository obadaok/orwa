<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surah_header_box"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/alyamama"
        android:text="التمرير التلقائي"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginVertical="12dp"
        android:background="@color/urwah_thread_brown" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/alyamama"
        android:text="سرعة التمرير"
        android:textColor="@color/urwah_thread_brown"
        android:textSize="14sp" />

    <SeekBar
        android:id="@+id/scrollSpeedSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="40" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/alyamama"
            android:gravity="start"
            android:text="بطيء"
            android:textColor="@color/urwah_thread_light"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvScrollSpeedValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/alyamama"
            android:text="40%"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/alyamama"
            android:gravity="end"
            android:text="سريع"
            android:textColor="@color/urwah_thread_light"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="@color/urwah_shadow_faint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelAutoScroll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_secondary_button"
            android:fontFamily="@font/alyamama"
            android:text="إلغاء"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnConfirmAutoScroll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="@font/alyamama"
            android:text="تشغيل"
            android:textColor="@color/urwah_background"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
