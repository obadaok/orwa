<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clipChildren="false">

    <View
        android:id="@+id/deleteBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_delete_swipe"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/bookmarkContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_surah_header_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <View
            android:id="@+id/colorDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBookmarkName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/alyamama"
                android:textColor="@color/urwah_thread_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBookmarkLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/alyamama"
                android:textColor="@color/urwah_thread_light"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
