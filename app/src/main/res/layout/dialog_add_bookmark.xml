<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surah_header_box"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/stc_forward"
        android:text="العلامات المرجعية"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_thread_brown" />

    <TextView
        android:id="@+id/tvExistingLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/stc_forward"
        android:text="تحديث علامة سابقة"
        android:textColor="@color/urwah_thread_brown"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExistingBookmarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:nestedScrollingEnabled="false"
        android:visibility="gone" />

    <View
        android:id="@+id/dividerExisting"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="@color/urwah_shadow_faint"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etBookmarkName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_search"
        android:fontFamily="@font/stc_forward"
        android:gravity="end|center_vertical"
        android:hint="اسم العلامة (اختياري)"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="@color/urwah_search_text"
        android:textColorHint="@color/urwah_search_hint"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/stc_forward"
        android:text="اختر لوناً (اختياري)"
        android:textColor="@color/urwah_thread_brown"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/colorPalette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="@color/urwah_shadow_faint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnSaveBookmark"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="@font/stc_forward"
            android:text="حفظ"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnCancelBookmark"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_secondary_button"
            android:fontFamily="@font/stc_forward"
            android:text="إلغاء"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
