<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surah_header_box"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/stc_forward"
        android:text="إعداد ختمة جديدة"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_thread_brown" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/stc_forward"
        android:text="البدء من الجزء:"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <NumberPicker
        android:id="@+id/pickerStartJuz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:descendantFocusability="blocksDescendants"
        android:theme="@style/NumberPickerTheme" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="6dp"
        android:background="@color/urwah_shadow_faint" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/stc_forward"
        android:text="مدة الختمة (بالأيام):"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <NumberPicker
        android:id="@+id/pickerDays"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:descendantFocusability="blocksDescendants"
        android:theme="@style/NumberPickerTheme" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="6dp"
        android:background="@color/urwah_shadow_faint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/urwah_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/stc_forward"
            android:text="الورد اليومي"
            android:textColor="@color/urwah_thread_light"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvWirdPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/stc_forward"
            android:textColor="@color/urwah_thread_brown"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="@color/urwah_shadow_faint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCreateKhatma"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_primary_button"
                android:fontFamily="@font/stc_forward"
                android:text="ابدأ الختمة"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnCancelKhatma"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_secondary_button"
                android:fontFamily="@font/stc_forward"
                android:text="إلغاء"
                android:textColor="@color/urwah_thread_dark"
                android:textSize="14sp" />
        </LinearLayout>
</LinearLayout>
