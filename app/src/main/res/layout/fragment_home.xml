<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/urwah_carousel_bg">

    <!-- قائمة التصنيفات - سكرول عمودي بتأثير تركيز مركزي -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingTop="100dp"
        android:paddingBottom="90dp" />

    <!-- الشريط العلوي الثابت -->
    <LinearLayout
        android:id="@+id/layout_topbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_topbar_fade">

        <ImageView
            android:id="@+id/iv_settings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_crescent_24dp"
            android:tint="@color/urwah_topbar_icon"
            android:contentDescription="الإعدادات"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/iv_search_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_search_black_24dp"
            android:tint="@color/urwah_topbar_icon"
            android:contentDescription="بحث"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" />
    </LinearLayout>

    <!-- لوحة البحث المنبثقة المركزية -->
    <FrameLayout
        android:id="@+id/layout_search_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/urwah_overlay_scrim"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="90dp"
            android:layout_marginHorizontal="28dp"
            android:orientation="vertical"
            android:background="@drawable/bg_search_panel"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search"
                android:paddingHorizontal="12dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/noto_naskh_arabic"
                    android:hint="ابحث عن ذكر..."
                    android:gravity="end|center_vertical"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/urwah_search_text"
                    android:textColorHint="@color/urwah_search_hint"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/iv_search_close"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_close_black_24dp"
                    android:tint="@color/urwah_search_hint"
                    android:contentDescription="إغلاق البحث"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
