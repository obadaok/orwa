<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/urwah_background">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_duas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="64dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@color/urwah_nav_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="@color/urwah_thread_dark"
            android:contentDescription="رجوع"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="@font/alyamama"
            android:text="الأدعية"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_search_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_search"
            android:tint="@color/urwah_thread_dark"
            android:contentDescription="بحث"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:visibility="visible" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:background="@color/urwah_shadow_faint" />

    <FrameLayout
        android:id="@+id/layout_search_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/urwah_overlay_scrim"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="64dp"
            android:layout_marginHorizontal="28dp"
            android:orientation="vertical"
            android:background="@drawable/bg_search_panel"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search"
                android:paddingHorizontal="12dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/alyamama"
                    android:hint="ابحث في الأدعية..."
                    android:gravity="end|center_vertical"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="@color/urwah_search_text"
                    android:textColorHint="@color/urwah_search_hint"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/iv_search_close"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_cancel"
                    android:tint="@color/urwah_search_hint"
                    android:contentDescription="إغلاق البحث"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
