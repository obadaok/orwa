<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_surah_header_box"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/alyamama"
        android:text="طريقة عرض الآيات"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="48dp"
        android:layout_height="2dp"
        android:layout_gravity="center"
        android:layout_marginVertical="12dp"
        android:background="@color/urwah_thread_brown" />

    <LinearLayout
        android:id="@+id/optionSingleLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dhikr_icon_action"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:id="@+id/radioSingleLine"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_ayah_number"
            android:gravity="center"
            android:textColor="@color/urwah_background"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/alyamama"
            android:text="كل آية في سطر مستقل"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="15sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="10dp"
        android:background="@color/urwah_shadow_faint" />

    <LinearLayout
        android:id="@+id/optionContinuous"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dhikr_icon_action"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:id="@+id/radioContinuous"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_ayah_number"
            android:gravity="center"
            android:textColor="@color/urwah_background"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/alyamama"
            android:text="عرض متواصل"
            android:textColor="@color/urwah_thread_dark"
            android:textSize="15sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="@color/urwah_shadow_faint" />

    <Button
        android:id="@+id/btnCancelViewMode"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_secondary_button"
        android:fontFamily="@font/alyamama"
        android:text="إلغاء"
        android:textColor="@color/urwah_thread_dark"
        android:textSize="14sp" />

</LinearLayout>
