<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_popup_ayah"
    android:elevation="8dp"
    android:paddingHorizontal="6dp"
    android:paddingVertical="6dp">

    <ImageView
        android:id="@+id/btnAddBookmark"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="إضافة علامة مرجعية"
        android:padding="10dp"
        android:src="@drawable/ic_bookmark_filled"
        android:tint="@color/urwah_topbar_icon" />

    <View
        android:layout_width="1dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:background="@color/urwah_shadow_faint" />

    <ImageView
        android:id="@+id/btnClearHighlight"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="إلغاء التحديد"
        android:padding="10dp"
        android:src="@drawable/ic_close_black_24dp"
        android:tint="@color/urwah_thread_light" />

</LinearLayout>
