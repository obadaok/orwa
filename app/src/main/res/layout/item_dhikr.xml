<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="10dp"
    android:clipChildren="false">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:clipChildren="false">

        <View
            android:id="@+id/deleteBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.0"
            android:background="@drawable/bg_delete_swipe"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/cardDhikrItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surah_header_box"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/bg_ripple_rounded"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp">

            <!-- Header: dhikr text + counter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtDhikrText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/alyamama"
                    android:gravity="center"
                    android:justificationMode="inter_word"
                    android:lineSpacingExtra="6dp"
                    android:textColor="@color/urwah_thread_dark"
                    android:textIsSelectable="false"
                    android:textSize="20sp" />

                <com.urwah.dhikr.CircularCounterView
                    android:id="@+id/circularCounter"
                    android:layout_width="52dp"
                    android:layout_height="52dp" />
            </LinearLayout>

            <!-- Virtue box with side bar -->
            <LinearLayout
                android:id="@+id/containerVirtue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_dhikr_virtue_box"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtVirtue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/alyamama"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/urwah_thread_dark"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtReference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.55"
                android:fontFamily="@font/alyamama"
                android:textColor="@color/urwah_thread_light"
                android:textSize="11sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginVertical="10dp"
                android:background="@color/urwah_shadow_faint" />

            <!-- Footer: action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnFavorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_favorites"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="مفضلة" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_share"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="مشاركة" />

                <ImageView
                    android:id="@+id/btnCopy"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_copy"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="نسخ" />
            </LinearLayout>
        </LinearLayout>

        <com.urwah.dhikr.ConfettiView
            android:id="@+id/confettiView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>
</FrameLayout>
