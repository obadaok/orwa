<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="10dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_dhikr_shadow_rect" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDhikrItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="5dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/urwah_thread_dark"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header: dhikr text + counter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtDhikrText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="@font/noto_naskh_arabic"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:textColor="@color/urwah_thread_dark"
                    android:textSize="18sp" />

                <com.urwah.dhikr.CircularCounterView
                    android:id="@+id/circularCounter"
                    android:layout_width="52dp"
                    android:layout_height="52dp" />
            </LinearLayout>

            <!-- Virtue box with side bar -->
            <LinearLayout
                android:id="@+id/containerVirtue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_dhikr_virtue_box"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtVirtue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/noto_naskh_arabic"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/urwah_thread_dark"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtReference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.55"
                android:fontFamily="@font/noto_naskh_arabic"
                android:textColor="@color/urwah_thread_light"
                android:textSize="11sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:layout_marginVertical="10dp"
                android:background="@color/urwah_shadow_faint" />

            <!-- Footer: action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnFavorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_favorite_black_24dp"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="مفضلة" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_share_black_24dp"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="مشاركة" />

                <ImageView
                    android:id="@+id/btnCopy"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_dhikr_icon_action"
                    android:padding="9dp"
                    android:src="@drawable/ic_content_copy_black_24dp"
                    android:tint="@color/urwah_thread_light"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="نسخ" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.urwah.dhikr.ConfettiView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false" />
</FrameLayout>
