<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:start="6dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/urwah_card_shadow" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:bottom="6dp"
        android:end="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/urwah_card_bg" />
            <corners android:radius="18dp" />
            <stroke
                android:width="3dp"
                android:color="@color/urwah_thread_dark" />
        </shape>
    </item>

</layer-list>
